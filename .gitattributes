# Auto-detect text files and normalize line endings
* text=auto

# Web text/code files
*.html text eol=lf
*.htm text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.sass text eol=lf
*.less text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.svg text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.csv text eol=lf
*.php text eol=lf
*.py text eol=lf
*.rb text eol=lf
*.go text eol=lf
*.rs text eol=lf
*.sh text eol=lf
*.sql text eol=lf

# Shell scripts should stay executable when committed from Unix/macOS
*.sh text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Images via Git LFS
*.jpg filter=lfs diff=lfs merge=lfs -text
