
server {
    listen 80;
    server_name _;
    
    access_log /var/log/nginx/access.log;
    error_log  /var/log/nginx/error.log warn;

    root /usr/share/nginx/html;
    index index.htm;

    location = /discord {
        return 302 https://discord.gg/m6zqemfmvD;
    }

    location / {
        #try_files $uri $uri/ /index.htm;
        try_files $uri $uri/ =404;
    }
}
